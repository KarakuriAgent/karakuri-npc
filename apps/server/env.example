# .env にコピーして使用する（cp env.example .env）
# サーバーポート
PORT=8300
# SQLite / 永続化データの置き場所
DATA_DIR=./data
# karakuri-world のベース URL（全 NPC 共通）。例 https://world.example.com
WORLD_BASE_URL=
# world に登録する公開 https URL（webhook 受信用）。ローカル開発では cloudflared 等のトンネル URL
WEBHOOK_PUBLIC_BASE_URL=
# NPC 配置 UI 用のワールドマップ YAML 置き場（karakuri-world の定義 YAML をコピーして置く）
# メインワールドは main.yaml、サブワールドは <world_id>.yaml という名前にする
WORLD_MAP_DIR=./maps
# WebUI のパスワード（未設定なら認証なし。localhost 運用専用）
WEB_PASSWORD=
# 既定 LLM（OpenAI 互換 API）
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
# Anthropic を使う場合
ANTHROPIC_API_KEY=
# プロセス全体の LLM 同時実行数
LLM_MAX_CONCURRENCY=4
